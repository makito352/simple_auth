
# ==========================================
# フロントエンド開発用 Dockerfile
# 使用技術: Next.js, Node.js 20
# ==========================================
FROM node:20-alpine

WORKDIR /app

# 依存関係のインストール
COPY package.json package-lock.json ./
RUN npm ci

# ソースコードのコピー
# 開発環境では docker-compose.override.yml によるホストとのマウントを行うため、
# Dockerfile内での COPY . は省略またはコメントアウト。
# COPY . .

# 環境変数の設定
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ARG ENV
ENV ENV=${ENV}

EXPOSE 3000

# 開発モードで起動
CMD ["npm", "run", "dev"]